#!/bin/sh
# Block pushes to main unless npm run build succeeds.

protected_branch="main"

while read local_ref local_sha remote_ref remote_sha; do
  branch=$(echo "$remote_ref" | sed 's|refs/heads/||')
  if [ "$branch" = "$protected_branch" ]; then
    echo "Running npm run build before push to $protected_branch..."
    npm run build
    if [ $? -ne 0 ]; then
      echo "Build failed. Push to $protected_branch blocked."
      exit 1
    fi
  fi
done

exit 0
